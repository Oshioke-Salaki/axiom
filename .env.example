# =============================================================================
# AXIOM Protocol — Environment Configuration
# =============================================================================
# Copy this to .env and fill in your values
# cp .env.example .env

# =============================================================================
# Agent Wallets (Base Sepolia)
# Fund these with Sepolia ETH from: https://www.alchemy.com/faucets/base-sepolia
# =============================================================================
PRIVATE_KEY=0x...                           # Master agent + deployer wallet
MASTER_AGENT_PRIVATE_KEY=0x...              # Nexus-1 (can be same as PRIVATE_KEY)
SENTIMENT_AGENT_PRIVATE_KEY=0x...           # Sentinel-1 (needs a little ETH)
ONCHAIN_AGENT_PRIVATE_KEY=0x...             # ChainEye-1 (needs a little ETH)

# Public addresses of sub-agents (derived from private keys above)
SENTIMENT_AGENT_ADDRESS=0x...
ONCHAIN_AGENT_ADDRESS=0x...

# =============================================================================
# Network — Base Sepolia
# =============================================================================
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# Or use Alchemy/Infura for reliability:
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# =============================================================================
# Deployed Contract Addresses (set after running forge deploy)
# =============================================================================
AGENT_REGISTRY_ADDRESS=0x...
COVENANT_PROTOCOL_ADDRESS=0x...
REPUTATION_SYSTEM_ADDRESS=0x...

# =============================================================================
# Filecoin Onchain Cloud (FOC)
# Testnet (calibration): no USDFC needed for small amounts
# Get tFIL: https://faucet.calibnet.chainsafe-fil.io
# Get tUSDFC: https://stg.usdfc.net
# =============================================================================
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_PRIVATE_KEY=0x...                  # Wallet with tFIL/tUSDFC balance

# =============================================================================
# Bankr LLM Gateway
# Get your key at: https://bankr.bot/api
# Enable "LLM Gateway" and add USDC credits at: https://bankr.bot/llm
# =============================================================================
BANKR_LLM_KEY=bk_...
DEFAULT_LLM_MODEL=claude-sonnet-4-6

# =============================================================================
# Optional: BaseScan API for deployment verification
# =============================================================================
BASESCAN_API_KEY=...
